#!/bin/bash -e
# Remove re-downloadable caches under $HOME on shared /arc (complements astroai-cache-prune on scratch).

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh
for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

STALE_PKG=0
ML=0
HF=0
LOGS=0
XDG_JUNK=0
ALL=0
DRY_RUN=0

# Paths we never touch (prefixes under $HOME).
_PROTECTED=(
    "${HOME}/.ssh"
    "${HOME}/.config"
    "${HOME}/.astroai/saves"
    "${HOME}/.local/bin"
    "${HOME}/.local/share/uv/python"
    "${HOME}/.local/share/uv/tools"
)

usage() {
    cat <<'EOF' >&2
astroai-home-clean — clear re-downloadable junk under $HOME on /arc.
Usage: astroai-home-clean --all-safe | (--stale-pkg | --ml | --logs | --xdg-junk | --hf)...
  --help for details
EOF
    exit 1
}

help_full() {
    cat <<'EOF'
astroai-home-clean — clear re-downloadable junk under $HOME on /arc.

Targets persistent home storage (CephFS), not TMP_SCRATCH_DIR download caches.
Use astroai-cache-prune for scratch/env-var package caches. Run astroai-home-usage
first to see what's using space.

Usage:
  astroai-home-clean --all-safe
  astroai-home-clean (--stale-pkg | --ml | --logs | --xdg-junk | --hf)...

Options:
  --stale-pkg     Legacy package caches under $HOME (pip/uv/npm/pixi/conda) when
                  active caches live on TMP_SCRATCH_DIR or TMP_SRC_DIR.
  --ml            ML/tool caches: torch, matplotlib, numba, jupyter, ipython.
  --logs          Old AstroAI debug logs and auto-archive log.
  --xdg-junk      Other safe ~/.cache dirs (pre-commit, mypy, pytest, ruff, …).
  --hf            Remove HF_HOME (models must be re-downloaded — expensive).
  --all-safe      --stale-pkg --ml --logs --xdg-junk (does NOT include --hf).
  --dry-run       Show what would be removed; do not delete.
  -h              Short usage summary.
  --help          Show this detailed help.

Never removes:
  ~/.ssh, ~/.config, ~/.astroai/saves, ~/.local/bin,
  ~/.local/share/uv/{python,tools}, pixi/micromamba envs (only stale caches).

Examples:
  astroai-home-clean --dry-run --all-safe
  astroai-home-clean --all-safe
  astroai-home-clean --ml --hf
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --stale-pkg) STALE_PKG=1; shift ;;
        --ml) ML=1; shift ;;
        --hf) HF=1; shift ;;
        --logs) LOGS=1; shift ;;
        --xdg-junk) XDG_JUNK=1; shift ;;
        --all-safe) ALL=1; shift ;;
        --dry-run) DRY_RUN=1; shift ;;
        -h) usage ;;
        --help) help_full ;;
        *) astroai_err "Unknown option: $1"; usage ;;
    esac
done

if [[ "${ALL}" -eq 1 ]]; then
    STALE_PKG=1; ML=1; LOGS=1; XDG_JUNK=1
fi

if [[ "${STALE_PKG}" -eq 0 && "${ML}" -eq 0 && "${HF}" -eq 0 && "${LOGS}" -eq 0 && "${XDG_JUNK}" -eq 0 ]]; then
    usage
fi

_xdg_cache="${XDG_CACHE_HOME:-${HOME}/.cache}"
_mamba_root="${MAMBA_ROOT_PREFIX:-${HOME}/.local/share/micromamba}"
_pixi_home="${PIXI_HOME:-${HOME}/.pixi}"

astroai_home_canon() {
    local p="$1"
    [[ -e "${p}" ]] && realpath "${p}" 2>/dev/null || printf '%s' "${p}"
}

astroai_home_under_home() {
    local target="$1"
    local home_canon target_canon
    home_canon="$(astroai_home_canon "${HOME}")"
    target_canon="$(astroai_home_canon "${target}")"
    [[ "${target_canon}" == "${home_canon}" || "${target_canon}" == "${home_canon}/"* ]]
}

astroai_home_is_protected() {
    local target="$1"
    local prot target_canon prot_canon
    target_canon="$(astroai_home_canon "${target}")"
    for prot in "${_PROTECTED[@]}"; do
        prot_canon="$(astroai_home_canon "${prot}")"
        [[ "${target_canon}" == "${prot_canon}" || "${target_canon}" == "${prot_canon}/"* ]] && return 0
    done
    return 1
}

astroai_home_is_active_pkg_cache() {
    local target="$1"
    local var path target_canon path_canon
    target_canon="$(astroai_home_canon "${target}")"
    for var in PIP_CACHE_DIR UV_CACHE_DIR NPM_CONFIG_CACHE PIXI_CACHE_DIR MAMBA_PKGS_DIRS CONDA_PKGS_DIRS; do
        path="${!var:-}"
        [[ -n "${path}" ]] || continue
        path_canon="$(astroai_home_canon "${path}")"
        [[ "${target_canon}" == "${path_canon}" ]] && return 0
    done
    return 1
}

_removed_bytes=0

astroai_home_clean_remove() {
    local target="$1"
    local label="${2:-${target}}"

    [[ -e "${target}" ]] || return 0

    if ! astroai_home_under_home "${target}"; then
        astroai_warn "Skip (outside \$HOME): ${target}"
        return 0
    fi
    if astroai_home_is_protected "${target}"; then
        astroai_warn "Skip (protected): ${target}"
        return 0
    fi

    local bytes human
    bytes="$(du -sb "${target}" 2>/dev/null | awk '{print $1}')"
    human="$(du -sh "${target}" 2>/dev/null | awk '{print $1}')"

    if [[ "${DRY_RUN}" -eq 1 ]]; then
        astroai_info "[dry-run] would remove ${human}  ${label}"
        _removed_bytes=$((_removed_bytes + bytes))
        return 0
    fi

    astroai_info "Removing ${human}  ${label}..."
    rm -rf "${target}"
    _removed_bytes=$((_removed_bytes + bytes))
}

astroai_home_clean_glob() {
    local pattern="$1"
    local label="$2"
    local f
    shopt -s nullglob
    for f in ${pattern}; do
        astroai_home_clean_remove "${f}" "${label:-${f}}"
    done
    shopt -u nullglob
}

if [[ "${STALE_PKG}" -eq 1 ]]; then
    astroai_section "Stale package caches under \$HOME"
    _stale_pkg_paths=(
        "${HOME}/.cache/pip"
        "${HOME}/.cache/uv"
        "${HOME}/.cache/npm"
        "${HOME}/.cache/conda/pkgs"
        "${_pixi_home}/cache"
        "${HOME}/.npm"
        "${_mamba_root}/pkgs"
    )
    for _path in "${_stale_pkg_paths[@]}"; do
        if [[ -e "${_path}" ]]; then
            if astroai_home_is_active_pkg_cache "${_path}"; then
                astroai_hint "Skip (active cache): ${_path}"
            else
                astroai_home_clean_remove "${_path}" "${_path}"
            fi
        fi
    done
fi

if [[ "${ML}" -eq 1 ]]; then
    astroai_section "ML / notebook caches"
    _ml_paths=(
        "${TORCH_HOME:-${_xdg_cache}/torch}"
        "${MPLCONFIGDIR:-${_xdg_cache}/matplotlib}"
        "${_xdg_cache}/numba"
        "${_xdg_cache}/jupyter"
        "${_xdg_cache}/ipython"
    )
    for _path in "${_ml_paths[@]}"; do
        astroai_home_clean_remove "${_path}" "${_path}"
    done
fi

if [[ "${XDG_JUNK}" -eq 1 ]]; then
    astroai_section "Other safe ~/.cache entries"
    _xdg_paths=(
        "${_xdg_cache}/pre-commit"
        "${_xdg_cache}/mypy"
        "${_xdg_cache}/pytest"
        "${_xdg_cache}/ruff"
        "${_xdg_cache}/fontconfig"
        "${_xdg_cache}/thumbnails"
        "${_xdg_cache}/node-gyp"
        "${_xdg_cache}/go-build"
        "${_xdg_cache}/dvc"
        "${_xdg_cache}/wandb"
    )
    for _path in "${_xdg_paths[@]}"; do
        astroai_home_clean_remove "${_path}" "${_path}"
    done
fi

if [[ "${LOGS}" -eq 1 ]]; then
    astroai_section "AstroAI logs"
    astroai_home_clean_glob "${HOME}/.astroai/debug-"*.log "debug logs"
    if [[ -f "${HOME}/.astroai/auto-archive.log" ]]; then
        if [[ "${DRY_RUN}" -eq 1 ]]; then
            _log_human="$(du -sh "${HOME}/.astroai/auto-archive.log" 2>/dev/null | awk '{print $1}')"
            astroai_info "[dry-run] would truncate ${_log_human}  ${HOME}/.astroai/auto-archive.log"
        else
            astroai_info "Truncating ${HOME}/.astroai/auto-archive.log..."
            : > "${HOME}/.astroai/auto-archive.log"
        fi
    fi
fi

if [[ "${HF}" -eq 1 ]]; then
    astroai_section "Hugging Face models"
    _hf="${HF_HOME:-${_xdg_cache}/huggingface}"
    if [[ -d "${_hf}" ]]; then
        astroai_warn "Removing ${_hf} — models will need to be re-downloaded."
        astroai_home_clean_remove "${_hf}" "${_hf}"
    fi
fi

echo ""
if [[ "${DRY_RUN}" -eq 1 ]]; then
    _total_h="$(numfmt --to=iec-i --suffix=B "${_removed_bytes}" 2>/dev/null || echo "?")"
    astroai_ok "Dry run complete. Would reclaim ~${_total_h}. Run without --dry-run to delete."
else
    astroai_ok "Done. Check: astroai-home-usage"
fi
