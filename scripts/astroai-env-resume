#!/bin/bash -e
set -o pipefail
# Restore a saved pixi or uv environment onto TMP_SRC_DIR.
#
# Usage:
#   astroai-env-resume <name>
#   astroai-env-resume <name> <target-dir>
#   astroai-env-resume <name> --from /arc/projects/group/env-saves/mylab

for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh
if [[ -n "${TMPDIR:-}" ]]; then
    mkdir -p "${TMPDIR}"
fi

usage() {
    cat <<'EOF' >&2
astroai-env-resume — restore a saved environment.
Usage: astroai-env-resume <name> [target] [--from <path>]
  --help for details
EOF
    exit 1
}

help_full() {
    cat <<'EOF'
astroai-env-resume — restore a saved environment.

Copies lockfiles from a previous astroai-env-save and rebuilds the
environment with pixi install or uv sync.

Usage:
  astroai-env-resume <name> [target-dir] [--from <path>]

Arguments:
  name              Name of the saved environment.
  target-dir        Directory to restore into (default: TMP_SRC_DIR/<name>).

Options:
  --from <path>     Restore from a custom save location instead of the
                    default save root.
  -h                Show short usage summary.
  --help            Show this detailed help.

Examples:
  astroai-env-resume mylab
  astroai-env-resume mylab /path/to/target
  astroai-env-resume mylab --from /arc/projects/group/env-saves/mylab

Notes:
  • After resume, register the kernel for JupyterLab:
      astroai-kernel-register
  • Full saves (--full) are extracted without rebuild.
  • Lockfile-only saves trigger pixi install / uv sync.
EOF
    exit 0
}

FROM_OVERRIDE=""
NAME=""
TARGET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --from)
            [[ -n "${2:-}" ]] || { echo "--from requires a path" >&2; exit 1; }
            FROM_OVERRIDE="$2"
            shift 2
            ;;
        -h) usage ;;
        --help) help_full ;;
        *)
            if [[ -z "${NAME}" ]]; then
                NAME="$1"
            else
                TARGET="$1"
            fi
            shift
            ;;
    esac
done

[[ -n "${NAME}" ]] || { astroai_err "Usage: astroai-env-resume <name> [target-dir]"; exit 1; }

SAVE_DIR="${FROM_OVERRIDE:-$(astroai_save_root)/${NAME}}"

[[ -f "${SAVE_DIR}/manifest.json" ]] || {
    astroai_err "Save not found: ${SAVE_DIR}"
    astroai_cmd "List saves: astroai-env-list"
    exit 1
}

KIND="$(jq -r .kind "${SAVE_DIR}/manifest.json")"
FULL="$(jq -r .full "${SAVE_DIR}/manifest.json")"
if [[ -z "${TARGET}" ]]; then
    TARGET="$(astroai_src_dir)/${NAME}"
fi

mkdir -p "${TARGET}"

for f in pixi.toml pixi.lock pyproject.toml uv.lock .python-version README.md; do
    [[ -f "${SAVE_DIR}/${f}" ]] && cp -a "${SAVE_DIR}/${f}" "${TARGET}/"
done

cd "${TARGET}"

if [[ "${FULL}" == "1" && -f "${SAVE_DIR}/env.tar.zst" ]]; then
    astroai_info "Extracting packed environment..."
    zstd -d -c "${SAVE_DIR}/env.tar.zst" | tar -xf -
    astroai_ok "Restored full pack in ${TARGET}"
else
    case "${KIND}" in
        pixi)
            command -v pixi >/dev/null || { astroai_err "pixi not found"; exit 1; }
            pixi install
            ;;
        uv)
            command -v uv >/dev/null || { astroai_err "uv not found"; exit 1; }
            uv sync
            ;;
        *)
            astroai_err "Unknown kind: ${KIND}"
            exit 1
            ;;
    esac
    astroai_ok "Rebuilt ${KIND} environment in ${TARGET}"
fi

astroai_cmd "cd ${TARGET}"
echo ""
astroai_hint "JupyterLab: astroai-kernel-register   # add this env to the kernel picker"
