#!/bin/bash -e
# List saved environment manifests.
#
# Usage:
#   astroai-env-list              personal saves only
#   astroai-env-list --team       team saves on /arc/projects
#   astroai-env-list --all        personal + team

source /opt/astroai/lib/astroai-env-common.sh

TEAM=0
ALL=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --team) TEAM=1; shift ;;
        --all)  ALL=1; shift ;;
        -h|--help)
            sed -n '2,7p' "$0"
            exit 0
            ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [[ "${ALL}" -eq 1 ]]; then
    TEAM=1
fi

SHOW_PERSONAL=1
if [[ "${TEAM}" -eq 1 && "${ALL}" -eq 0 ]]; then
    SHOW_PERSONAL=0
fi

list_saves() {
    local root="$1"
    local label="$2"

    if [[ ! -d "${root}" ]]; then
        echo "${label}: (none)"
        return
    fi

    local found=0
    while read -r m; do
        found=1
        dir="$(dirname "${m}")"
        name="$(jq -r .name "${m}")"
        kind="$(jq -r .kind "${m}")"
        at="$(jq -r .saved_at "${m}")"
        full="$(jq -r .full "${m}")"
        user="$(jq -r .user "${m}")"
        sz="$(du -sh "${dir}" 2>/dev/null | awk '{print $1}')"
        printf "  %-16s %-5s %s  full=%-5s %6s  %s\n" "${name}" "${kind}" "${at}" "${full}" "${sz}" "${user}"
    done < <(find "${root}" -name manifest.json 2>/dev/null)

    if [[ "${found}" -eq 0 ]]; then
        echo "${label}: (none)"
    fi
}

# ── Personal saves ──────────────────────────────
if [[ "${SHOW_PERSONAL}" -eq 1 ]]; then
    ROOT="$(astroai_save_root)"
    echo "Personal saves: ${ROOT}"
    list_saves "${ROOT}" "  "
fi

# ── Team saves ───────────────────────────────────
if [[ "${TEAM}" -eq 1 ]]; then
    echo ""
    echo "Team saves (/arc/projects/<project>/env-saves/):"
    if [[ -d /arc/projects ]]; then
        team_found=0
        for proj in /arc/projects/*/; do
            [[ -d "${proj}" && -r "${proj}" ]] || continue
            saves_dir="${proj}env-saves"
            if [[ -d "${saves_dir}" ]]; then
                team_found=1
                proj_name="$(basename "${proj}")"
                echo "  [${proj_name}]"
                list_saves "${saves_dir}" "    "
                echo ""
            fi
        done
        if [[ "${team_found}" -eq 0 ]]; then
            echo "  (no team env-saves found)"
        fi
    else
        echo "  /arc/projects not mounted"
    fi
fi

if [[ "${SHOW_PERSONAL}" -eq 1 ]]; then
    echo ""
    echo "Tip: team saves can live under /arc/projects/<group>/env-saves/"
    echo "     astroai-env-list --team"
    echo "     astroai-env-resume <name> --from /arc/projects/<group>/env-saves/<name>"
fi
